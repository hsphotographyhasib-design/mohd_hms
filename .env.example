# =============================================================
# Environment Variables — Copy this to .env and fill in values
# =============================================================

# REQUIRED: PostgreSQL connection string
# For Vercel: Use Neon, Supabase, or Vercel Postgres
# For local dev: Use the same cloud DB or a local PostgreSQL instance
# Example (Neon):     postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Example (Supabase): postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Example (local):    postgresql://postgres:postgres@localhost:5432/mydb
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT secret for authentication (generate a random 32+ char string)
JWT_SECRET="your-jwt-secret-here"

# Optional: App URL (used for email links, webhooks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"