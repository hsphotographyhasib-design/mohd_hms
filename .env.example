# ============================================================
# DATABASE
# ============================================================
# Local development (SQLite):
DATABASE_URL=file:./db/custom.db

# Production (PostgreSQL) — for Vercel deployment:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
# Free PostgreSQL options:
#   • Neon (https://neon.tech) — serverless, free tier
#   • Vercel Postgres (https://vercel.com/docs/storage/vercel-postgres)
#   • Supabase (https://supabase.com) — free tier
#
# IMPORTANT: When deploying to Vercel:
#   1. Create a PostgreSQL database (e.g., Neon)
#   2. Set DATABASE_URL in Vercel Environment Variables
#   3. Change prisma/schema.prisma: provider = "postgresql"
#   4. Run: npx prisma db push
# ============================================================

# ============================================================
# AUTH
# ============================================================
JWT_SECRET=your-jwt-secret-change-in-production

# ============================================================
# GOOGLE AUTH (optional)
# ============================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ============================================================
# NEXTAUTH
# ============================================================
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=