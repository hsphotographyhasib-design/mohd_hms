# ============ DATABASE ============
# Local development (SQLite file)
DATABASE_URL=file:./db/custom.db

# Production (Turso / libSQL) — uncomment below and comment out the local one
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# ============ AUTH ============
JWT_SECRET=your-super-secret-jwt-key-change-this
NEXT_PUBLIC_JWT_SECRET=your-public-jwt-secret-change-this

# ============ GOOGLE OAUTH ============
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ APP URL ============
# Set this to your Vercel deployment URL
NEXT_PUBLIC_APP_URL=https://mohd-hms.vercel.app

# ============ WHATSAPP SERVICE (optional) ============
# Only needed if running the WhatsApp mini-service separately
# WHATSAPP_SERVICE_URL=https://your-whatsapp-service.railway.app

# ============ EMAIL (password reset etc.) ============
# Optional — if neither is set, reset emails are logged to the server console.
# Resend (preferred):
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM=MOHD.HMS ENTERPRISE <no-reply@your-domain.com>
# Or generic HTTP SMTP relay accepting { to, from, subject, html, text }:
# SMTP_RELAY_URL=https://your-relay.example.com/send
# SMTP_RELAY_KEY=optional-bearer-token