# ============ DATABASE ============
# Local development (SQLite file)
DATABASE_URL=file:./db/custom.db

# Production (Turso / libSQL) — uncomment below and comment out the local one
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# ============ AUTH ============
JWT_SECRET=your-super-secret-jwt-key-change-this
NEXT_PUBLIC_JWT_SECRET=your-public-jwt-secret-change-this

# ============ APP URL ============
# Set this to your Vercel deployment URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============ WHATSAPP SERVICE (optional) ============
# Only needed if running the WhatsApp mini-service separately
# WHATSAPP_SERVICE_URL=https://your-whatsapp-service.railway.app