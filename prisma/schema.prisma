  @@index([complaintId, createdAt])
}

// ============ NOTIFICATIONS ============

model Notification {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  type          String   // complaint_assigned, status_update, pm_reminder, invoice_reminder, eta_update, workflow_transition, escalation
