// ============ COMPLAINT TIMELINE ============

model ComplaintTimeline {
  id              String   @id @default(cuid())
  tenantId        String
  complaintId     String
  action          String   // created, assigned, accepted, rejected, started, checklist_updated, completed, client_confirmed, client_rejected, rework_required, invoice_generated, invoice_approved, invoice_sent, payment_received, closed, status_override
  fromStatus      String?
  toStatus        String?
  description     String
  performedBy     String?  // userId
  performedByRole String?
