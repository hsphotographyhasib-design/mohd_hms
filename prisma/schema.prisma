// ============ WHATSAPP SYSTEM ============

// 19. WhatsApp Config - Provider settings per tenant
model WhatsAppConfig {
  id              String   @id @default(cuid())
  tenantId        String
  provider        String   @default("openwa") // openwa, meta, twilio
  isEnabled       Boolean  @default(false)
  phoneNumber     String?
  businessName    String?
  // OpenWA config
  openwaBaseUrl   String?  // e.g. http://localhost:3001
  openwaSession   String?
  openwaApiKey    String?
  openwaQrCode    String?  // base64 QR image
  openwaStatus    String   @default("disconnected") // connected, disconnected, connecting
  // Meta Cloud API config
  metaAccessToken String?
  metaPhoneNumberId String?
  metaVerifyToken String?
  metaWebhookSecret String?
  metaBusinessAccountId String?
  // Twilio config
  twilioAccountSid  String?
  twilioAuthToken   String?
  twilioPhoneNumber String?
  // General
  autoReplyEnabled  Boolean @default(true)
  welcomeMessage    String  @default("Welcome to MOHD.HMS ENTERPRISE!\n\nPlease choose:\n1️⃣ New Complaint\n2️⃣ Service Request\n3️⃣ Complaint Status\n4️⃣ My Equipment\n5️⃣ Work Order Status\n6️⃣ Invoices\n7️⃣ Emergency Service\n8️⃣ Speak to Customer Support")
  emergencyNumbers  String?  // JSON array of phone numbers
  defaultPriority   String  @default("medium")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  sessions        WhatsAppSession[]

  @@unique([tenantId])
}

// 20. WhatsApp Session - Per-customer conversation session
model WhatsAppSession {
  id              String   @id @default(cuid())
  tenantId        String
  configId        String
  phoneNumber     String   // customer WhatsApp number (international format)
  customerId      String?  // linked CMMS customer
  sessionId       String?  // provider session ID
  state           String   @default("menu") // menu, new_complaint_desc, new_complaint_media, new_complaint_equipment, service_request_desc, status_query, invoice_query, equipment_list, emergency_desc, feedback_rating, feedback_comment, escalation_desc, chat, appointment_date, appointment_time, appointment_location
  stateData       String?  // JSON - temp data for current flow step
  lastMessageAt   DateTime @default(now())
  messageCount    Int      @default(0)
  isActive        Boolean  @default(true)
  isBlocked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  config          WhatsAppConfig @relation(fields: [configId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  messages        WhatsAppMessage[]
  threads         ConversationThread[]

  @@index([tenantId, phoneNumber])
  @@index([phoneNumber])
  @@index([state])
}

// 21. WhatsApp Message - All messages (inbound + outbound)
model WhatsAppMessage {
  id              String   @id @default(cuid())
  tenantId        String
  sessionId       String
  threadId        String?
  direction       String   // inbound, outbound
  messageType     String   @default("text") // text, image, video, audio, document, location, contact, sticker
  content         String?  // text content
  mediaUrl        String?
  mediaType       String?
  thumbnailUrl    String?
  caption         String?
  location        String?  // JSON: {lat, lng, address}
  fromNumber      String?
  toNumber        String?
  providerMessageId String? // WhatsApp message ID from provider
  status          String   @default("sent") // sent, delivered, read, failed
  errorMessage    String?
  isFromBot       Boolean  @default(false)
  isTemplate      Boolean  @default(false)
  metadata        String?  // JSON - extra data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  session         WhatsAppSession @relation(fields: [sessionId], references: [id])
  thread          ConversationThread? @relation(fields: [threadId], references: [id])
  deliveryLogs    WhatsAppDeliveryLog[]

  @@index([tenantId, sessionId])
  @@index([sessionId])
  @@index([providerMessageId])
  @@index([createdAt])
}

// 22. Conversation Thread - Grouped conversations
model ConversationThread {
  id              String   @id @default(cuid())
  tenantId        String
  sessionId       String
  subject         String?
  status          String   @default("active") // active, resolved, archived
  assignedToId    String?  // staff member handling this thread
  lastMessageAt   DateTime @default(now())
  messageCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  session         WhatsAppSession @relation(fields: [sessionId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerId      String?
  messages        WhatsAppMessage[]

  @@index([tenantId, status])
  @@index([sessionId])
  @@index([assignedToId])
}

// 23. WhatsApp Template - Message templates
model WhatsAppTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  category        String   // welcome, complaint_created, assigned, in_progress, completed, invoice, feedback, emergency, appointment, notification, custom
  content         String   // template body with {{variables}}
  variables        String?  // JSON array of variable names
  mediaType       String?  // text, image, document
  mediaUrl        String?  // URL for template media
  isActive        Boolean  @default(true)
  isSystem        Boolean  @default(false) // system templates can't be deleted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId, category])
}

// 24. Customer Feedback via WhatsApp
model CustomerFeedback {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String
  complaintId     String?
  workOrderId     String?
  rating          Int      // 1-5
  comment         String?
  source          String   @default("whatsapp") // whatsapp, portal, email
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId, customerId])
}

// 25. Customer Report/Escalation via WhatsApp
model CustomerReport {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String
  sessionId       String?
  type            String   @default("escalation") // escalation, complaint, suggestion, other
  subject         String
  description     String
  priority        String   @default("medium")
  status          String   @default("OPEN") // OPEN, IN_REVIEW, RESOLVED, DISMISSED
  resolvedById    String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId, status])
}

// 26. Broadcast Log - Mass message campaigns
model BroadcastLog {
  id              String   @id @default(cuid())
  tenantId        String
  title           String
  content         String
  templateId      String?
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  deliveredCount  Int      @default(0)
  failedCount     Int      @default(0)
  readCount       Int      @default(0)
  status          String   @default("draft") // draft, scheduled, sending, completed, failed
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

// 27. WhatsApp Delivery Log - Per-message delivery tracking
model WhatsAppDeliveryLog {
  id              String   @id @default(cuid())
  tenantId        String
  messageId       String
  direction       String   // inbound, outbound
  status          String   // sent, delivered, read, failed, deleted
  providerStatus  String?  // raw provider status
  timestamp       DateTime @default(now())
  errorMessage    String?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  message         WhatsAppMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId])
  @@index([messageId])
}

// ============ WHATSAPP OTP AUTH ============

model OtpCode {
  id            String   @id @default(cuid())
  tenantId      String
  phoneNumber   String
  code          String
  purpose       String   @default("login") // login, registration, reset
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)
  expiresAt     DateTime
  verifiedAt    DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, phoneNumber])
  @@index([phoneNumber, expiresAt])
  @@index([expiresAt])
}

model LoginSession {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  refreshToken  String   @unique
  deviceName    String?
  deviceType    String?  // mobile, tablet, desktop
  browser       String?
  os            String?
  ipAddress     String?
  userAgent     String?
  isRevoked     Boolean  @default(false)
  lastActivity  DateTime @default(now())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([refreshToken])
  @@index([tenantId, userId])
}

model Device {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  name          String?
  type          String?  // mobile, tablet, desktop
  browser       String?
  os            String?
  ipAddress     String?
  userAgent     String?
  lastSeen      DateTime @default(now())
  isTrusted     Boolean  @default(false)
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tenantId, userId])
}
// ============ PASSWORD RESET & AUTH AUDIT ============

model PasswordResetToken {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  tokenHash     String   @unique  // SHA-256 hash of the raw token (raw token never stored)
  expiresAt     DateTime
  usedAt        DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId, userId])
  @@index([expiresAt])
}

model AuthAuditLog {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String?
  email         String?  // captured even for unknown-account events
  event         String   // password_reset_requested, reset_email_sent, token_verified, token_invalid, token_expired, password_changed, reset_failed, rate_limited
  success       Boolean  @default(true)
  ipAddress     String?
  userAgent     String?
  device        String?
  browser       String?
  metadata      String?  // JSON
  createdAt     DateTime @default(now())

  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([email])
  @@index([ipAddress])
  @@index([event])
}

// ============ TERMS ACCEPTANCE ============

model TermsAcceptance {
  id              String   @id @default(cuid())
  userId          String
  tcVersion       String
  privacyVersion  String
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tcVersion])
}

// ============ EMAIL SYSTEM ============

model EmailLog {
  id              String   @id @default(cuid())
  tenantId        String
  recipient       String
  cc              String?
  bcc             String?
  subject         String
  templateId      String?
  templateName    String?
  module          String?  // complaints, work-orders, invoices, quotations, auth, pm, equipment, inventory, finance, hr, inspection
  status          String   @default("queued") // queued, sending, delivered, opened, clicked, bounced, failed, spam, unsubscribed
  provider        String   @default("brevo") // brevo, console
  providerMessageId String?
  errorCode       String?
  errorMessage    String?
  retryCount      Int      @default(0)
  maxRetries      Int      @default(5)
  nextRetryAt     DateTime?
  scheduledFor    DateTime?
  ip              String?
  userAgent       String?
  metadata        String?  // JSON — stores module-specific data
  attachmentCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  bouncedAt       DateTime?

  template        EmailTemplate? @relation(fields: [templateId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, module])
  @@index([recipient])
  @@index([status])
  @@index([scheduledFor])
  @@index([nextRetryAt])
  @@index([providerMessageId])
  @@index([createdAt])
}

model EmailTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  identifier      String   // e.g., "complaint.created", "invoice.sent"
  subject         String
  module          String
  description     String?
  bodyHtml        String   // HTML template with {{variables}}
  bodyText        String?  // Plain text fallback
  variables       String?  // JSON array of variable names
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  emailLogs       EmailLog[]

  @@unique([tenantId, identifier])
  @@index([tenantId, module])
}
