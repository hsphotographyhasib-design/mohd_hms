generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ TENANT & MULTI-TENANCY ============

model Tenant {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  plan        String   @default("professional") // free, professional, enterprise
  maxUsers    Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  customers   Customer[]
  equipment   Equipment[]
  complaints  Complaint[]
  workOrders  WorkOrder[]
  invoices    Invoice[]
  quotations  Quotation[]
  pmSchedules PmSchedule[]
  inventory             InventoryItem[]
  inventoryCategories   InventoryCategory[]
  inventorySubcategories InventorySubcategory[]
  inventoryWarehouses   Warehouse[]
  inventorySuppliers    ItemSupplier[]
  stockMovements        StockMovement[]
  warehouseStocks       WarehouseStock[]
  priceBooks            PriceBook[]
  priceBookEntries      PriceBookEntry[]
  purchaseOrders PurchaseOrder[]
  vehicles    Vehicle[]
  departments Department[]
  notifications Notification[]
  auditLogs   AuditLog[]
  checklistTemplates ChecklistTemplate[]
  whatsappConfigs      WhatsAppConfig[]
  whatsappSessions     WhatsAppSession[]
  whatsappMessages     WhatsAppMessage[]
  conversationThreads  ConversationThread[]
  whatsappTemplates    WhatsAppTemplate[]
  broadcastLogs        BroadcastLog[]
  whatsappDeliveryLogs WhatsAppDeliveryLog[]
  customerFeedbacks    CustomerFeedback[]
  customerReports      CustomerReport[]
  complaintTimelines   ComplaintTimeline[]
  equipmentQrCodes     EquipmentQrCode[]
  scanLogs             ScanLog[]
  otpCodes             OtpCode[]
  loginSessions        LoginSession[]
  devices              Device[]
  passwordResetTokens  PasswordResetToken[]
  authAuditLogs        AuthAuditLog[]
  emailLogs            EmailLog[]
  emailTemplates       EmailTemplate[]
}

// ============ USERS & AUTH ============

model User {
  id            String   @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String?
  name          String
  phone         String?
  avatar        String?
  role          String   @default("technician") // super_admin, admin, manager, supervisor, technician, finance, customer, vendor, guest
  employeeNumber String?
  departmentId  String?
  authProvider  String?  // "email", "google", "whatsapp"
  googleId      String?  // Google sub (unique user ID)
  isActive      Boolean  @default(true)
  isOnline      Boolean  @default(false)
  lastLogin     DateTime?
  gpsLocation   String?  // JSON: {lat, lng}
  profileCompleted Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  assignedComplaints  Complaint[]  @relation("TechnicianComplaints")
  assignedWorkOrders  WorkOrder[]  @relation("TechnicianWorkOrders")
  supervisedWorkOrders WorkOrder[] @relation("SupervisorWorkOrders")
  createdWorkOrders   WorkOrder[]  @relation("CreatorWorkOrders")
  createdInvoices     Invoice[]    @relation("CreatorInvoices")
  preparedInvoices    Invoice[]    @relation("PreparerInvoices")
  pmSchedules   PmSchedule[] @relation("PmScheduleAssignee")
  supervisorComplaints Complaint[] @relation("SupervisorComplaints")
  auditLogs    AuditLog[]
  vehicleLogs  VehicleLog[]
  loginSessions LoginSession[]
  devices      Device[]
  passwordResetTokens PasswordResetToken[]
  authAuditLogs AuthAuditLog[]
  termsAcceptances TermsAcceptance[]

  @@unique([tenantId, email])
  @@unique([googleId])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([tenantId, departmentId])
  @@index([tenantId, employeeNumber])
  @@index([phone])
}

// ============ DEPARTMENTS ============

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  headId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  users       User[]

  @@index([tenantId])
}

// ============ CUSTOMERS ============

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  email         String?
  phone         String
  address       String?
  gpsLocation   String?  // JSON: {lat, lng}
  companyName   String?
  customerNumber String @unique
  photo         String?
  paymentTerms  String?  // e.g. "50% advance, balance upon completion"
  pic           String?  // Person in Charge
  country       String?  @default("Brunei")
  district      String?
  taxRate       Float    @default(0)
  isActive      Boolean  @default(true)
  isWhatsappVerified  Boolean  @default(false)
  whatsappId          String?
  whatsappPhone       String?
  lastWhatsappActivity DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  equipment   Equipment[]
  complaints  Complaint[]
  invoices    Invoice[]
  quotations  Quotation[]
  conversationThreads ConversationThread[]
  whatsappSessions     WhatsAppSession[]
  customerFeedbacks    CustomerFeedback[]
  customerReports      CustomerReport[]
  workOrders           WorkOrder[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, isActive])
}

// ============ EQUIPMENT ============

model Equipment {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String?
  name            String
  category        String   // HVAC, Electrical, Plumbing, Generator, Mechanical, FireProtection
  assetNumber     String   @unique
  qrCode          String   @unique
  qrId            String?   @unique  // QR-GEN-NFYH3RZAA format, used for public URLs
  brand           String?
  model           String?
  serialNumber    String?
  location        String?
  building        String?
  room            String?
  installDate     DateTime?
  warrantyExpiry  DateTime?
  warrantyInfo    String?
  status          String   @default("active") // active, inactive, under_maintenance, decommissioned, critical, out_of_service, overdue_pm
  condition       String   @default("good") // good, fair, poor, critical
  photos          String?  // JSON array of URLs
  documents       String?  // JSON array of URLs
  specifications  String? // JSON object
  notes           String?
  scanCount       Int      @default(0)
  lastScannedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  customer        Customer?    @relation(fields: [customerId], references: [id])
  complaints      Complaint[]
  workOrders      WorkOrder[]
  pmSchedules     PmSchedule[]
  scanLogs        ScanLog[]
  qrCodeRecord    EquipmentQrCode?
}

// ============ EQUIPMENT QR CODES ============

model EquipmentQrCode {
  id            String   @id @default(cuid())
  tenantId      String
  equipmentId   String   @unique
  qrId          String   @unique  // QR-GEN-NFYH3RZAA
  qrUrl         String              // https://domain.com/equipment/QR-GEN-NFYH3RZAA
  isActive      Boolean  @default(true)
  generatedAt   DateTime @default(now())
  lastRegeneratedAt DateTime?
  version       Int      @default(1)

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  equipment     Equipment @relation(fields: [equipmentId], references: [id])
}

// ============ SCAN LOGS ============

model ScanLog {
  id            String   @id @default(cuid())
  tenantId      String
  equipmentId   String
  qrId          String
  scannedBy     String?  // userId or null for anonymous
  scannedByName String?  // "Anonymous" for public scans
  ipAddress     String?
  userAgent     String?
  device        String?  // mobile, desktop, tablet
  browser       String?
  location      String?  // geo if available
  referer       String?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  equipment     Equipment @relation(fields: [equipmentId], references: [id])

  @@index([tenantId, equipmentId])
  @@index([qrId])
  @@index([createdAt])
}

// ============ COMPLAINTS ============

model Complaint {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String
  equipmentId     String?
  title           String
  description     String
  priority        String   @default("medium") // low, medium, high, critical
  status          String   @default("NEW")
  // Workflow: NEW, ASSIGNED, ACCEPTED, WORK_ORDER_CREATED, IN_PROGRESS,
  //           WAITING_CLIENT_CONFIRMATION, CLIENT_CONFIRMED, DRAFT_INVOICE,
  //           INVOICE_APPROVED, INVOICE_SENT, PAID, CLOSED, REWORK_REQUIRED
  source          String   @default("admin") // portal, whatsapp, admin, qr_scan, mobile_app
  category        String?  // HVAC, Electrical, Plumbing, etc.
  photos          String?  // JSON array
  gpsLocation     String?  // JSON: {lat, lng}
  assignedToId    String?
  supervisorId    String?
  assignedBy      String?  // userId of the admin/supervisor who assigned the technician
  assignedByRole  String?  // role of the assigner (admin, supervisor, super_admin, manager)
  assignedAt      DateTime? // when the current technician was assigned
  lastReassignedAt DateTime? // last reassignment timestamp
  assignmentReason String?  // reason for assignment or reassignment
  assignmentStatus String  @default("UNASSIGNED") // UNASSIGNED, PENDING_ACCEPTANCE, ACCEPTED, REJECTED
  reassignmentCount Int    @default(0) // tracks how many times this complaint has been reassigned
  slaResponseDeadline DateTime?  // deadline for technician to accept (e.g. 15min from assignment)
  workOrderId     String?  // linked work order (generated on ACCEPTED)
  invoiceId       String?  // linked invoice (generated on CLIENT_CONFIRMED)
  eta             String?  // technician ETA
  rejectionReason String?  // if technician rejects
  reworkReason    String?  // if customer requests rework
  resolutionNotes String?
  customerRating  Int?
  customerFeedback String?
  acceptedAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  clientConfirmedAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  customer      Customer @relation(fields: [customerId], references: [id])
  equipment     Equipment? @relation(fields: [equipmentId], references: [id])
  assignedTo    User?    @relation("TechnicianComplaints", fields: [assignedToId], references: [id])
  supervisor    User?    @relation("SupervisorComplaints", fields: [supervisorId], references: [id])
  workOrders    WorkOrder[]
  notifications Notification[]
  timeline      ComplaintTimeline[]

  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, assignedBy])
}

// ============ WORK ORDERS ============

model WorkOrder {
  id              String   @id @default(cuid())
  tenantId        String
  workOrderNumber String?  @unique // e.g. WO/HMS/2026/000001
  complaintId     String?
  customerId      String?
  equipmentId     String?
  assetId         String?  // optional asset linkage
  title           String
  description     String
  source          String   @default("manual") // complaint, preventive, manual, quotation, service_request, inspection_report
  reference       String?  // e.g. Complaint ID, PM ID, SR ID
  status          String   @default("DRAFT") // DRAFT, PENDING, ASSIGNED, ACCEPTED, IN_PROGRESS, COMPLETED, CLOSED, CANCELLED
  priority        String   @default("medium") // emergency, high, medium, low
  type            String   @default("corrective") // corrective, preventive, emergency, inspection, installation, breakdown
  category        String?
  subCategory     String?
  sla             String?
  estimatedHours  Float?
  assignedToId    String?
  supervisorId    String?
  teamId          String?
  createdBy        String?
  scheduledDate   DateTime?
  startTime       String?  // HH:mm format
  dueDate         DateTime?
  dueTime         String?  // HH:mm format
  siteId          String?
  building        String?
  floor           String?
  internalNotes   String?
  checklistId     String?
  // Safety & Compliance
  permitRequired        Boolean @default(false)
  lockoutTagoutRequired Boolean @default(false)
  highRiskWork          Boolean @default(false)
  safetyEquipmentReq    Boolean @default(false)
  safetyNotes           String?  // additional safety requirements
  // Existing fields
  startedAt       DateTime?
  completedAt     DateTime?
  checkInGps      String?  // JSON: {lat, lng, timestamp}
  checkOutGps     String?  // JSON: {lat, lng, timestamp}
  laborHours      Float?
  laborCost       Float?
  materialCost    Float?
  totalCost       Float?
  notes           String?
  photos          String?  // JSON array
  beforePhotos    String?  // JSON array
  afterPhotos     String?  // JSON array
  videoUrl        String?
  materialsUsed   String?  // JSON: [{name, qty, unit, cost}]
  checklistData   String?  // JSON: completed checklist
  remarks         String?
  technicianSignature String?
  customerSignature   String?
  serviceReportPdf   String?
  attachments     String?  // JSON: [{name, url, size, type, uploadedAt}]
  isLocked        Boolean  @default(false)
  isDraft         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  complaint       Complaint? @relation(fields: [complaintId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  equipment       Equipment? @relation(fields: [equipmentId], references: [id])
  assignedTo      User?    @relation("TechnicianWorkOrders", fields: [assignedToId], references: [id])
  supervisor      User?    @relation("SupervisorWorkOrders", fields: [supervisorId], references: [id])
  creator         User?    @relation("CreatorWorkOrders", fields: [createdBy], references: [id])
  materials       WorkOrderMaterial[]
  invoices        Invoice[]

  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, workOrderNumber])
}

model WorkOrderMaterial {
  id            String   @id @default(cuid())
  workOrderId   String
  inventoryItemId String
  quantity      Int
  unitCost      Float
  totalCost     Float

  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

// ============ CHECKLIST TEMPLATES ============

model ChecklistTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String   // HVAC, Electrical, Plumbing, Generator, etc.
  description String?
  items       String   // JSON array of checklist items
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

// ============ PREVENTIVE MAINTENANCE ============

model PmSchedule {
  id            String   @id @default(cuid())
  tenantId      String
  equipmentId   String
  title         String
  description   String?
  frequency     String   // monthly, quarterly, half_yearly, yearly, custom
  customDays    Int?
  lastExecuted  DateTime?
  nextDueDate   DateTime
  assignedToId  String?
  status        String   @default("active") // active, paused, completed
  checklistTemplateId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  equipment     Equipment @relation(fields: [equipmentId], references: [id])
  assignedTo    User?    @relation("PmScheduleAssignee", fields: [assignedToId], references: [id])
}

// ============ QUOTATIONS ============

model Quotation {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String
  complaintId     String?
  quotationNo     String?  // e.g. QTN/SMSB/01/4529
  title           String
  description     String?
  referenceNo     String?  // internal reference
  projectName     String?
  site            String?
  preparedBy      String?  // userId
  items           String   // JSON array of line items
  terms           String?  // JSON array of terms & conditions
  currency        String   @default("BND")
  subtotal        Float
  taxRate         Float    @default(0)
  tax             Float    @default(0)
  discount        Float    @default(0)
  shipping        Float    @default(0)
  total           Float
  status          String   @default("DRAFT") // DRAFT, REVIEW, APPROVED, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED_WO, CONVERTED_INVOICE, PAID, CLOSED
  validUntil      DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  sentAt          DateTime?
  acceptedAt      DateTime?
  pdfUrl          String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  customer      Customer @relation(fields: [customerId], references: [id])
  invoices      Invoice[]
}

// ============ INVOICES ============

model Invoice {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String
  workOrderId     String?
  quotationId     String?
  invoiceNumber   String   @unique
  title           String
  description     String?
  items           String   // JSON array of line items: [{title,description,unit,quantity,rate,amount}]
  subtotal        Float
  taxRate         Float    @default(0)
  tax             Float    @default(0)
  discount        Float    @default(0)
  shipping        Float    @default(0)
  total           Float
  status          String   @default("DRAFT") // DRAFT, PENDING, APPROVED, PAID, CANCELLED, OVERDUE
  currency        String   @default("BND")
  referenceNo     String?  // linked quotation number
  poReference     String?  // customer PO number
  paymentTerms    String?  // e.g. "30 Days"
  dueDate         DateTime?
  paidAt          DateTime?
  paymentMethod   String?
  paymentRef      String?
  transactionId   String?  // bank transaction ID
  bankName        String?
  bankAccountName String?
  bankAccountNo   String?
  sentVia         String?  // email, whatsapp, portal
  pdfUrl          String?
  notes           String?
  terms           String?  // JSON array of terms & conditions
  shipToName      String?
  shipToAddress   String?
  shipToPhone     String?
  shipToContact   String?
  preparedBy      String?  // userId
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  customer      Customer @relation(fields: [customerId], references: [id])
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])
  quotation     Quotation? @relation(fields: [quotationId], references: [id])
  creator       User?    @relation("CreatorInvoices", fields: [createdBy], references: [id])
  preparer      User?    @relation("PreparerInvoices", fields: [preparedBy], references: [id])

  @@index([tenantId, status])
}

// ============ INVENTORY - ENTERPRISE ITEM MASTER ============

model InventoryCategory {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  code          String?  // e.g. HVAC, ELEC, PLMB
  description   String?
  icon          String?
  color         String?  // hex color
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  items         InventoryItem[]
  subcategories InventorySubcategory[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model InventorySubcategory {
  id            String   @id @default(cuid())
  tenantId      String
  categoryId    String
  name          String
  code          String?
  description   String?
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  category      InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items         InventoryItem[]

  @@unique([tenantId, categoryId, name])
  @@index([tenantId])
  @@index([categoryId])
}

model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String

  // === IDENTITY ===
  itemCode      String?  @unique  // Auto-generated: ITM/HMS/2026/000001
  sku           String?  @unique
  barcode       String?  @unique
  qrCode        String?
  name          String
  shortName     String?

  // === CLASSIFICATION ===
  itemType      String   @default("inventory") // inventory, spare_part, consumable, service, manpower, equipment_package, supply_only, supply_install, rental
  categoryId    String?
  subcategoryId String?

  // === DESCRIPTION ===
  description   String?
  shortDescription String?

  // === PHYSICAL ATTRIBUTES ===
  brand         String?
  manufacturer  String?
  model         String?
  partNumber    String?
  serialNumber  String?
  unit          String   @default("pcs")
  unitWeight    Float?
  dimensions    String?  // JSON: {length, width, height, unit}

  // === PRICING ===
  purchaseCost      Float    @default(0)
  averageCost       Float    @default(0)
  standardCost      Float    @default(0)
  lastPurchaseCost  Float    @default(0)
  sellingPrice      Float    @default(0)
  dealerPrice       Float    @default(0)
  contractorPrice   Float    @default(0)
  customerPrice     Float    @default(0)
  vipPrice          Float    @default(0)
  internalCost      Float    @default(0)
  labourCost        Float    @default(0)
  installationCost  Float    @default(0)
  serviceCost       Float    @default(0)
  transportationCost Float    @default(0)
  mobilizationCost  Float    @default(0)
  equipmentRental   Float    @default(0)
  emergencyCallOut  Float    @default(0)
  afterHoursCharge  Float    @default(0)
  weekendCharge     Float    @default(0)
  publicHolidayCharge Float  @default(0)
  currency          String   @default("BND")

  // === STOCK (for physical items) ===
  quantity      Int      @default(0)
  minStock      Int      @default(0)
  maxStock      Int?
  reorderLevel  Int      @default(0)
  safetyStock   Int      @default(0)

  // === LEGACY FIELDS (kept for backward compat) ===
  unitCost      Float    @default(0)
  supplier      String?
  location      String?

  // === MEDIA ===
  photos        String?  // JSON array of URLs
  attachments   String?  // JSON array of document URLs
  technicalDatasheet String?
  msds          String?

  // === WARRANTY & ORIGIN ===
  warranty      String?
  warrantyExpiry DateTime?
  countryOfOrigin String?
  hsCode        String?

  // === TAGS & STATUS ===
  tags          String?  // JSON array of strings
  status        String   @default("draft") // draft, pending_approval, active, inactive, archived, discontinued
  approvalStatus String  @default("pending") // pending, supervisor_review, manager_approved, admin_approved, rejected
  approvedBy    String?
  approvedAt    DateTime?

  // === VERSIONING ===
  version       Int      @default(1)

  // === MANPOWER-SPECIFIC ===
  hourlyRate    Float?
  dailyRate     Float?
  overtimeRate  Float?
  weekendRate   Float?
  publicHolidayRate Float?

  // === RENTAL-SPECIFIC ===
  dailyRentalRate  Float?
  monthlyRentalRate Float?

  // === SERVICE PACKAGE-SPECIFIC ===
  estimatedHours  Float?
  requiredSkills  String? // JSON array
  sop             String? // Standard Operating Procedure

  // === MISC ===
  remarks       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  category      InventoryCategory? @relation(fields: [categoryId], references: [id])
  subcategory   InventorySubcategory? @relation(fields: [subcategoryId], references: [id])
  workOrderMaterials WorkOrderMaterial[]
  suppliers     ItemSupplier[]
  stockMovements StockMovement[]
  warehouseStock WarehouseStock[]
  priceBookEntries PriceBookEntry[]

  @@index([tenantId])
  @@index([tenantId, itemType])
  @@index([tenantId, categoryId])
  @@index([tenantId, status])
  @@index([tenantId, isActive])
  @@index([sku])
  @@index([barcode])
  @@index([name])
}

// ============ WAREHOUSES ============

model Warehouse {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  code          String?
  type          String   @default("main") // main, sub_warehouse, vehicle, technician, project, temporary
  address       String?
  manager       String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  stocks        WarehouseStock[]
  movements     StockMovement[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model WarehouseStock {
  id            String   @id @default(cuid())
  tenantId      String
  warehouseId   String
  itemId        String
  quantity      Int      @default(0)
  reserved      Int      @default(0)
  damaged       Int      @default(0)
  returned      Int      @default(0)
  batchNo       String?
  lotNumber     String?
  expiryDate    DateTime?
  costMethod    String   @default("fifo") // fifo, lifo, weighted_average
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, itemId])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([itemId])
}

// ============ ITEM SUPPLIERS ============

model ItemSupplier {
  id            String   @id @default(cuid())
  tenantId      String
  itemId        String
  supplierName  String
  supplierCode  String?
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  leadTimeDays  Int      @default(0)
  purchasePrice Float    @default(0)
  moq           Int      @default(1) // Minimum Order Quantity
  warranty      String?
  paymentTerms  String?
  rating        Int?     // 1-5
  isPrimary     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([itemId])
  @@index([supplierName])
}

// ============ STOCK MOVEMENTS ============

model StockMovement {
  id            String   @id @default(cuid())
  tenantId      String
  itemId        String
  warehouseId   String?
  type          String   // stock_in, stock_out, adjustment, transfer, return, damage
