  previousQty   Int      @default(0)
  newQty        Int      @default(0)
  reason        String?
  referenceNo   String?  // PO number, WO number, etc.
  referenceType String?  // purchase_order, work_order, adjustment, transfer
  fromWarehouseId String? // For transfers
  batchNo       String?
  lotNumber     String?
  expiryDate    DateTime?
  unitCost      Float    @default(0)
  notes         String?
  performedBy   String?  // userId
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, itemId])
  @@index([tenantId, type])
  @@index([warehouseId])
}

// ============ PRICE BOOKS ============

model PriceBook {
  id            String   @id @default(cuid())
